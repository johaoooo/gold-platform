@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Montserrat:wght@700&display=swap');
@import "tailwindcss";
@theme {
  --color-bg: #05090a;
  --color-surface: #0a120b;
  --color-surface-2: #0f1f10;
  --color-gold: #10b981;
  --color-gold-light: #34d399;
  --color-gold-glow: #6ee7b7;
  --color-text-1: #ffffff;
  --color-text-2: #8fa894;
  --font-playfair: var(--font-playfair), serif;
  --font-syne: var(--font-syne), sans-serif;
  --font-dm: var(--font-dm), sans-serif;
}
:root {
  background-color: #05090a;
  color: white;
}
body {
  @apply bg-bg text-text-1 min-h-screen;
}
html, body {
  overflow-x: hidden;
  max-width: 100vw;
}

/* Styles globaux pour les titres */
.title-gold {
  font-family: Georgia, 'Times New Roman', serif;
  font-weight: bold;
  background: linear-gradient(135deg, #f0a500, #ffd87a);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  display: inline-block;
}

.title-gold-gradient {
  font-family: Georgia, 'Times New Roman', serif;
  font-weight: bold;
  background: linear-gradient(90deg, #f0a500, #ffd87a);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  display: inline-block;
}

.section-title {
  font-family: Georgia, 'Times New Roman', serif;
  font-weight: bold;
  font-size: 2.5rem;
  line-height: 1.2;
  color: white;
}

@media (min-width: 768px) {
  .section-title {
    font-size: 3rem;
  }
}

.section-subtitle {
  font-family: Georgia, 'Times New Roman', serif;
  font-weight: 500;
  font-size: 1.5rem;
  color: #f0a500;
}

/* Style vert comme sur la page d'accueil */
.title-green-gradient {
  background: linear-gradient(90deg, #22c55e, #4ade80);
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  display: inline-block;
}

/* Vert style accueil */
.text-vert-accueil {
  color: #4ade80;
}

.bg-vert-accueil {
  background-color: #4ade80;
}

.border-vert-accueil {
  border-color: #4ade80;
}
