import { ReactNode } from 'react';

interface ButtonProps {
  children: ReactNode;
  variant?: 'gold' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  className?: string;
  onClick?: () => void;
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
}

export default function Button({
  children,
  variant = 'gold',
  size = 'md',
  className = "",
  onClick,
  type = 'button',
  disabled = false,
}: ButtonProps) {
  const base = "rounded-full font-syne transition-all duration-300 text-center inline-block cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed";

  const variants = {
    // bg-gold = #2E7D32 (vert foncé) via tailwind.config
    // hover shadow vert — rgba(46,125,50,0.4)
    gold: "bg-gold text-white font-bold hover:bg-gold-light hover:shadow-[0_0_20px_rgba(46,125,50,0.5)]",
    outline: "border border-gold text-gold hover:bg-gold hover:text-white",
  };

  const sizes = {
    sm: "px-4 py-1.5 text-xs",
    md: "px-6 py-2.5 text-sm",
    lg: "px-10 py-4 text-lg",
  };

  return (
    <button
      type={type}
      onClick={onClick}
      disabled={disabled}
      className={`${base} ${variants[variant]} ${sizes[size]} ${className}`}
    >
      {children}
    </button>
  );
}