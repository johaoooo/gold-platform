'use client';

import { useState, useEffect } from 'react';
import Link from 'next/link';
import { useRouter } from 'next/navigation';
import Button from '../ui/Button';
import { getProjects } from '@/services/api';

interface Project {
  id: number;
  titre: string;
  secteur: string;
  montant_cible: number;
  montant_actuel: number;
  localisation: string;
  progression: number;
  description: string;
  porteur: string;
}

const secteurs = [
  { value: 'tous', label: 'Tous', icon: '🌍' },
  { value: 'tech', label: 'Tech', icon: '💻' },
  { value: 'agriculture', label: 'Agriculture', icon: '🌾' },
  { value: 'immobilier', label: 'Immobilier', icon: '🏢' },
  { value: 'energie', label: 'Énergie', icon: '⚡' },
];

export default function Projets() {
  const router = useRouter();
  const [secteurActif, setSecteurActif] = useState('tous');
  const [projets, setProjets] = useState<Project[]>([]);
  const [loading, setLoading] = useState(true);
  const [user, setUser] = useState<any>(null);

  useEffect(() => {
    const storedUser = localStorage.getItem('user');
    if (storedUser) {
      setUser(JSON.parse(storedUser));
    }
    fetchProjects();
  }, []);

  const fetchProjects = async () => {
    try {
      const response = await getProjects();
      setProjets(response.data);
    } catch (error) {
      console.error('Erreur:', error);
    } finally {
      setLoading(false);
    }
  };

  const projetsFiltres = secteurActif === 'tous'
    ? projets
    : projets.filter((p) => p.secteur === secteurActif);

  const formatMontant = (montant: number) => {
    return new Intl.NumberFormat('fr-FR').format(montant) + ' FCFA';
  };

  const getSecteurColor = (secteur: string) => {
    const colors: Record<string, string> = {
      tech: 'from-blue-500/20 to-blue-600/10 border-blue-500/30',
      agriculture: 'from-green-500/20 to-green-600/10 border-green-500/30',
      immobilier: 'from-purple-500/20 to-purple-600/10 border-purple-500/30',
      energie: 'from-yellow-500/20 to-yellow-600/10 border-yellow-500/30',
    };
    return colors[secteur] || 'from-gold/20 to-gold/10 border-gold/30';
  };

  const handleProposerProjet = () => {
    if (user && user.role === 'porteur') {
      router.push('/dashboard/porteur/nouveau-projet');
    } else if (user && user.role === 'investisseur') {
      alert('Seuls les porteurs de projet peuvent proposer un projet. Vous êtes investisseur.');
    } else {
      router.push('/connexion');
    }
  };

  if (loading) {
    return (
      <section className="py-20 bg-bg">
        <div className="max-w-6xl mx-auto px-6 text-center">
          <p className="text-text-2">Chargement des projets...</p>
        </div>
      </section>
    );
  }

  return (
    <section className="py-20 bg-gradient-to-b from-bg to-bg/95">
      <div className="max-w-6xl mx-auto px-6">
        <div className="text-center mb-12">
          <h2 className="text-4xl md:text-5xl font-playfair text-gold mb-4">
            Projets à financer
          </h2>
          <p className="text-text-2 font-dm max-w-2xl mx-auto">
            Découvrez des opportunités d'investissement dans des secteurs porteurs
          </p>
        </div>

        <div className="flex flex-wrap justify-center gap-3 mb-12">
          {secteurs.map((s) => (
            <button
              key={s.value}
              onClick={() => setSecteurActif(s.value)}
              className={`px-5 py-2.5 rounded-full font-syne text-sm transition-all duration-300 flex items-center gap-2 ${
                secteurActif === s.value
                  ? 'bg-gold text-surface font-semibold shadow-lg shadow-gold/20 scale-105'
                  : 'bg-surface-2 text-text-2 hover:bg-green-500/20 hover:text-green-400 border border-transparent hover:border-green-500/50'
              }`}
            >
              <span>{s.icon}</span>
              {s.label}
            </button>
          ))}
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {projetsFiltres.map((projet) => (
            <div
              key={projet.id}
              className={`group bg-gradient-to-br ${getSecteurColor(projet.secteur)} rounded-2xl overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-3 border`}
            >
              <div className="relative h-48 overflow-hidden">
                <div className="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent z-10" />
                <div className="w-full h-full bg-cover bg-center transform group-hover:scale-110 transition-transform duration-700"
                     style={{ backgroundImage: `url(/images/projects/${projet.secteur}.jpg)` }} />
                <div className="absolute top-4 right-4 z-20">
                  <span className="px-3 py-1 bg-gold text-surface text-xs font-syne font-bold rounded-full shadow-lg">
                    {projet.secteur}
                  </span>
                </div>
              </div>
              <div className="p-6">
                <h3 className="text-xl font-playfair text-gold mb-2 group-hover:text-gold-light transition-colors">
                  {projet.titre}
                </h3>
                <p className="text-text-2 font-dm text-sm mb-4 line-clamp-2">
                  {projet.description}
                </p>
                <div className="flex justify-between items-center text-sm mb-3">
                  <span className="text-gold font-semibold">{formatMontant(projet.montant_cible)}</span>
                  <span className="text-text-2 flex items-center gap-1">
                    <span>📍</span> {projet.localisation}
                  </span>
                </div>
                <div className="mb-4">
                  <div className="flex justify-between text-xs text-text-2 mb-1">
                    <span>Progression</span>
                    <span className="text-gold font-semibold">{projet.progression}%</span>
                  </div>
                  <div className="w-full bg-surface-2 rounded-full h-2 overflow-hidden">
                    <div
                      className="bg-gradient-to-r from-gold to-green-400 rounded-full h-2 transition-all duration-1000"
                      style={{ width: `${projet.progression}%` }}
                    />
                  </div>
                </div>
                <div className="flex items-center justify-between text-xs text-text-2 mb-4">
                  <span className="flex items-center gap-1">
                    <span>👤</span> {projet.porteur}
                  </span>
                  <span className="flex items-center gap-1">
                    <span>💰</span> {formatMontant(projet.montant_actuel)} collectés
                  </span>
                </div>
                <Link href={`/projets/${projet.id}`}>
                  <Button variant="outline" size="md" className="w-full group-hover:bg-gold group-hover:text-surface transition-all duration-300 border-green-500/50">
                    Voir le projet →
                  </Button>
                </Link>
              </div>
            </div>
          ))}
        </div>

        <div className="text-center mt-12">
          <Button 
            variant="gold" 
            size="lg" 
            className="px-8 py-4 text-lg hover:scale-105 transition-transform"
            onClick={handleProposerProjet}
          >
            Proposer mon projet
          </Button>
        </div>
      </div>
    </section>
  );
}
